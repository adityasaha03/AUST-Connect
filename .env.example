# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/aust_connect

# ─── Auth / JWT ──────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
